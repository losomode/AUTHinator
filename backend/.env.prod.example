# Authinator — Production Environment
# Copy to .env.prod and fill in real values before deploying.

SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DEBUG=False

# Set to your deployment domain (e.g. www.yourapp.com)
DEPLOY_DOMAIN=www.yourapp.com
DEPLOY_SCHEME=https

ALLOWED_HOSTS=www.yourapp.com,yourapp.com

# SQLite path — written to the Docker named volume
SQLITE_PATH=/app/backend/data/db.sqlite3

FRONTEND_URL=https://www.yourapp.com

# CORS / CSRF (automatically derived from DEPLOY_DOMAIN if not set)
CORS_ALLOWED_ORIGINS=https://www.yourapp.com

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourapp.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@yourapp.com

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Service Registry
SERVICE_REGISTRATION_KEY=change-me-to-a-strong-random-key
